{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sync: git pull（GitHub の最新を手元に取り込む）",
      "type": "shell",
      "command": "echo '=== 開いた直後の git pull（AI事業コンテキスト）===' && git pull --ff-only && echo '=== 完了 ==='",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false,
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 1
      }
    }
  ]
}
